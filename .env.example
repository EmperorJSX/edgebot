# edgebot env. Every value has a devnet default in src/config/env.ts, so an
# empty .env runs the mock demo. Copy to .env and fill in only what you need.

APP_NAME=edgebot

# --- Solana (devnet) ---
SOLANA_RPC=https://api.devnet.solana.com
# Agent's own signer as a JSON array of the 64-byte secret key (Solana CLI
# `solana-keygen` format, same as the TxLINE example _keys/*.json). Leave unset
# to run the mock venue with an ephemeral key. Required + funded for proofsettle.
# AGENT_KEYPAIR_SECRET=[12,34,...]

# --- TxLINE (consensus odds) ---
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
TXLINE_LEAGUES=
# Optional pre-acquired creds. Set both to skip guest-start + on-chain subscribe.
# TXLINE_JWT=
# TXLINE_API_TOKEN=

# --- Venue (default mock, always demoable) ---
VENUE=mock
MOCK_EDGE=0.05
# proofsettle (skeleton). Program id + bet mint of proofsettle's devnet markets.
# PROOFSETTLE_PROGRAM_ID=
# PROOFSETTLE_BET_MINT=

# --- Strategy ---
START_BANKROLL=1000
MIN_EDGE=0.03
KELLY_FRACTION=0.25
PER_MATCH_CAP=0.1
TOTAL_CAP=0.5
MIN_STAKE=1

# --- Run mode ---
MODE=live
REPLAY_FILE=fixtures/sample-worldcup.jsonl
REPLAY_SPEED_MS=250
GRADE_INTERVAL_MS=60000

# --- Storage ---
DATA_DIR=data
